# PromptOS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Core Application
# =============================================================================
ENVIRONMENT=development
PORT=5000
APP_URL=http://localhost:5000
WEB_APP_URL=http://localhost:3000

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://promptos:promptos@localhost:5432/promptos
POSTGRES_USER=promptos
POSTGRES_PASSWORD=promptos
POSTGRES_DB=promptos

# =============================================================================
# Redis Cache
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_ISSUER=https://api.promptos.com
JWT_AUDIENCE=https://app.promptos.com
JWT_EXPIRES_IN=3600

# =============================================================================
# AI Providers
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_AI_API_KEY=your-google-ai-key-here

# =============================================================================
# OAuth Providers
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Azure Services
# =============================================================================
AZURE_KEY_VAULT_URI=https://your-vault.vault.azure.net
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_CONTAINER=uploads

# =============================================================================
# Logging & Monitoring
# =============================================================================
SENTRY_DSN=your-sentry-dsn-here
